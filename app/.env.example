OPENAI_API_KEY=
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres

# Test user — created manually in Supabase Studio (Authentication → Add User).
# The pytest suite signs in as this user to get a real JWT for API calls.
# Never used in any code path outside tests.

HUBSPOT_TOKEN=
APOLLO_API_KEY=
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_CLIENTS_TABLE_ID=
AIRTABLE_PROJECTS_TABLE_ID=
AIRTABLE_REVENUE_TABLE_ID=

# Harvest
HARVEST_TOKEN=
HARVEST_ACCOUNT_ID=

# Forecast (uses same bearer token as Harvest)
FORECAST_ACCOUNT_ID=


# Test User Credentials
TEST_USER_EMAIL=test-user@test.com
TEST_USER_PASSWORD=TestPassword123!